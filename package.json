    "@payloadcms/plugin-seo": "^3.77.0",
    "@payloadcms/richtext-lexical": "^3.77.0",
    "@payloadcms/sdk": "^3.77.0",
    "@payloadcms/ui": "^3.77.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cross-env": "^10.1.0",
    "graphql": "^16.11.0",
    "lucide-react": "^0.562.0",
    "next": "16.1.1",
    "next-pwa": "^5.6.0",
    "next-themes": "^0.4.6",
