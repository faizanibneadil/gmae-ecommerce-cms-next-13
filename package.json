    "@payloadcms/live-preview-react": "^3.77.0",
    "@payloadcms/next": "^3.77.0",
    "@payloadcms/plugin-form-builder": "^3.77.0",
    "@payloadcms/plugin-multi-tenant": "^3.77.0",
